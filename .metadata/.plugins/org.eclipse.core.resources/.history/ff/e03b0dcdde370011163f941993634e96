// 추상 클래스 작성
abstract class Car {
	// 자동차 모델명
	private String model;
	// 추상 메서드
	abstract void drive();
	
	public Car(String model) {
		this.model = model;
	}
}

// getModel 이라는 통로를 통해 이름을 가져와서 출력 
public void getModel() {
	System.out.println( this.model + "입니다.");
}

class sedan extends Car {
	@Override
	void drive() {
		System.out.println("부드럽게");
	}
}

class Truck extends Car {
	@Override
	void drive() {
		System.out.println("짐을 싣고");
	}
}

