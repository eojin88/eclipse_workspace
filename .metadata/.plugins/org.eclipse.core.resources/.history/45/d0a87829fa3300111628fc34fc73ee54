// 0 = 가위, 1 = 바위, 2 = 보
package rock_sisor_paper;

import java.util.Random;

public class rock_sisor_paper_01 {
	public static void main(String[] args) {
		Random r = new Random();
		
		int num = r.nextInt(3);
		System.out.println(num);
		
		if (num == 0) {
			System.out.println("가위");
		}
		else if (num == 1) {
			System.out.println("바위");
		}
		else {
			System.out.println("보");
		}
	}
}