package Quiz_260414;
	
interface Electric {
	void charge(); 
}

abstract class Car {
	private String model;

	abstract void drive();
}

class sedan extends Car {
	@Override
	void drive() {
		System.out.println("부드럽게");
	}
}

class Truck extends Car {
	@Override
	void drive() {
		System.out.println("짐을 싣고");
	}
}

public class abstract_car{
	public static void main(String[] args) {
		sedan s = new sedan();
		s.drive();
	}
}


