package Quiz_260414;
	
// 인터페이스 정의
interface Electric {
	void charge(); 
}

// 추상 클래스 작성
abstract class Car {
	// 자동차 모델명
	private String model;
	// 추상 메서드
	abstract void drive();
	
	public Car(String model) {
		this.model = model;
	}

	// getModel 이라는 통로를 통해 이름을 가져와서 출력 
	public void getModel() {
		System.out.println( this.model + " 입니다.");
	}
}

// Sedan 
class Sedan extends Car implements Electric {
	public Sedan(String model) {
		super(model);
	}
	
	@Override
	void drive() {
		System.out.println("부드럽게");
	}
	
	@Override
	public void charge() {
		System.out.println("세단 충전 중...");
		System.out.println();
	}
}

// Truck
class Truck extends Car implements Electric {
	public Truck(String model) {
		super(model);
	}
	
	@Override
	void drive() {
		System.out.println("짐을 싣고");
	}
	
	@Override
	public void charge() {
		System.out.println("트럭 충전 중...");
		System.out.println();
	}
}

//Tesla
class Tesla extends Car implements Electric {
	public Tesla(String model) {
		super(model);
	}
	
	@Override
	void drive() {
		System.out.println("전기로 달린다");
	}
	
	@Override
	public void charge() {
		System.out.println("테슬라 충전 중...");
		System.out.println();
	}
}

//Tesla_Truck
class Tesla_Truck extends Car implements Electric {
	public Tesla_Truck(String model) {
		super(model);
	}
	
	@Override
	void drive() {
		System.out.println("화물을 적재하고 전기로 달린다");
	}
	
	@Override
	public void charge() {
		System.out.println("테슬라 충전 중...");
		System.out.println();
	}
}

// 실행
public class abstract_car {
	public static void main(String[] args) {
//		sedan s = new sedan();
//		s.drive();
//		Truck t = new Truck();
//		t.drive();

		Car[] cars = new Car[4];
		cars[0] = new Sedan("소나타");
		cars[1] = new Truck("포터");
		cars[2] = new Tesla("모델3");
		cars[3] = new Tesla_Truck("사이버 트럭");

		for (Car c : cars) {
			c.getModel();
			c.drive();

			// Electric 기능은 형변환 필요
		for(Car car : cars) {
			if (c instanceof Tesla || c instanceof Tesla_Truck) {
				((Electric) c).charge();
			}
		}
		}

	}
}






