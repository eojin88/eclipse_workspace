package Quiz_260414;
	
// 인터페이스 정의
interface Electric {
	void charge(); 
}

// 추상 클래스 작성
abstract class Car {
	// 자동차 모델명
	private String model;
	// 추상 메서드
	abstract void drive();
	
	public Car(String model) {
		this.model = model;
	}

	// getModel 이라는 통로를 통해 이름을 가져와서 출력 
	public void getModel() {
		System.out.println( this.model + "입니다.");
	}
}

// Sedan 
class Sedan extends Car implements Electric {
	public Sedan(String model) {
		super(model);
	}
	
	@Override
	void drive() {
		System.out.println("부드럽게");
	}
	
	@Override
	public void charge() {
		System.out.println("세단 충전 중...");
	}
}

// Truck
class Truck extends Car implements Electric {
	public Truck(String model) {
		super(model);
	}
	
	@Override
	void drive() {
		System.out.println("짐을 싣고");
	}
	
	@Override
	public void charge() {
		System.out.println("트럭 충전 중...");
	}
}

public class abstract_car{
	public static void main(String[] args) {
