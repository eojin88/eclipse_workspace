package Quiz_260414;

// toString 사용할려면 필요하다고함!
import java.util.Arrays;

public class Quiz_duplicate_delete {

	// toString 사용하여 초기배열 출력 
	public static void main(String[] args) {
		
		int[] a = {1, 3, 3, 4, 5, 2, 6, 7, 6, 7};
		System.out.println("---------------------------------------");
		System.out.print("초기 배열: ");
		System.out.println(Arrays.toString(a));
		System.out.println("---------------------------------------");
		System.out.println();
		System.out.println();

		int[] duplicate_delete = new int[a.length];
		// 초기값 0
		int count = 0;
		int temp = 0;
		int swapcount = 0;
		
		System.out.println("중복 제거 과정");
		System.out.println("--------------");
		for(int x = 0; x < a.length; x++) {
			boolean duplicate = false;
			
			for(int y = 0; y < count; y++) {
				if(a[x] == duplicate_delete[y]) {
					duplicate = true;
				}
			}
			
			// 중복 아닐때
			if (!duplicate) {
	            duplicate_delete[count] = a[x];
	            count++;
	            System.out.println(a[x] + " 추가됨");
	        }
			// 중복 일때
			if (duplicate) {
	            System.out.println(a[x] + " 중복이라 제거됨");
	        }
	    }
		System.out.println("--------------");
		System.out.println();
		System.out.println();
		System.out.println("swap 발생 과정");
		System.out.println("------------------");
		
		// 선택 정렬 
		for(int x = 0; x < count; x++) {
			for(int y = x + 1; y < count; y++) {
				if(duplicate_delete[x] < duplicate_delete[y]) {
					
					// swap 전 로그 출력
					System.out.println("swap 전: " + duplicate_delete[x] + " <-> " + duplicate_delete[y]);
					
					temp = duplicate_delete[x];
					duplicate_delete[x] = duplicate_delete[y];
					duplicate_delete[y] = temp;
					swapcount++;
					
					// swap 후 로그 출력 
					System.out.println("swap 후: " + duplicate_delete[x] + " --- " + duplicate_delete[y]);
					System.out.println();
				}
			}
		}
		System.out.println("------------------");
		// 총 swap 횟수 출력 
		System.out.println("총 swap 횟수: " + swapcount + "회");
		System.out.println("------------------");
		System.out.println();
		System.out.println();
		System.out.println("내림차순 정렬: ");
		System.out.println("-----------");
		// 내림차순 정렬 출력 
		for(int x = 0; x < count; x++) {
			System.out.println(duplicate_delete[x]);
		}
		System.out.println("-----------");
	}
	

}
