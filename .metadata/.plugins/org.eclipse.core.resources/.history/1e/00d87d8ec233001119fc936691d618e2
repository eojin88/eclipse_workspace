// 컴퓨터 선택을 "가위/바위/보" 문자열로 출력하기
// 사용자 선택과 컴퓨터 선택을 함께 출력하여 대결 구조 만들기
package rock_sisor_paper;

import java.util.Random;
import java.util.Scanner;

public class rock_sisor_paper_6 {
	public static void main(String[] args) {
		Random ra = new Random();
		Scanner sc = new Scanner(System.in);

		while (true) {
			System.out.print("입력: ");
			String input = sc.nextLine();

			if (!(input.equals("0") || input.equals("1") || input.equals("2") || input.equals("q"))) {
				System.out.println("잘못된 입력입니다. 다시 입력하세요.");
				continue;
			}
			
			String user = "";

			if (input.equals("0")) user = "가위";
			else if (input.equals("1")) user = "바위";
			else if (input.equals("2")) user = "보";
			else if (input.equals("q")) {
			    System.out.println("종료합니다.");
			    break;
			}
			System.out.println("사용자: " + user);
			
			int com = ra.nextInt(3);

			switch (com) {
			case 0:
				System.out.println("컴퓨터: 가위");
				break;
			case 1:
				System.out.println("컴퓨터: 바위");
				break;
			case 2:
				System.out.println("컴퓨터: 보");
				break;

			}	
			if (user.equals("가위") && com == 1) {
				System.out.println("결과: 컴퓨터 승리");
		    }
			else if (user.equals("가위") && com == 2) {
				System.out.println("결과: 사용자 승리");
			}
			else if (user.equals("가위") && com == 0) {
				System.out.println("결과: 무승부");
			}
			else if (user.equals("바위") && com == 1) {
				System.out.println("결과: 무승부");
			}
			else if (user.equals("바위") && com == 2) {
				System.out.println("결과: 컴퓨터 승리");
			}
			else if (user.equals("바위") && com == 0) {
				System.out.println("결과: 사용자 승리");
			}
			else if (user.equals("보") && com == 1) {
				System.out.println("결과: 사용자 승리");
			}
			else if (user.equals("보") && com == 2) {
				System.out.println("결과: 무승부");
			}
			else if (user.equals("보") && com == 0) {
				System.out.println("결과: 컴퓨터 승리");
			}
			
		}
		sc.close();
	}
}

